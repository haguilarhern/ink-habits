<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      "Paper & Ink" — a monochrome, paper-like system in the spirit of reMarkable and
      Apple's restraint. Pure white paper, crisp near-black ink, a small ladder of true
      grays tuned for e-ink legibility (hairlines stay solid enough not to dither),
      and solid-ink fills for active/selected/primary states. The user's handwriting is
      the only organic element on the page.
    -->

    <!-- Surfaces -->
    <color name="ink_background">#FFFFFF</color>   <!-- page -->
    <color name="ink_surface">#FFFFFF</color>      <!-- cards / rows -->
    <color name="ink_card">#FFFFFF</color>

    <!-- Text ladder (Apple label hierarchy, darkened for e-ink) -->
    <color name="ink_text">#0B0B0C</color>         <!-- primary label -->
    <color name="ink_text_soft">#3A3A3C</color>    <!-- emphasised body -->
    <color name="ink_text_muted">#5C5C5C</color>   <!-- secondary label -->
    <color name="ink_hint">#9A9AA0</color>         <!-- tertiary / placeholder -->

    <!-- Lines (solid enough to render cleanly on Carta/Kaleido) -->
    <color name="ink_divider">#D9D9DE</color>      <!-- hairline separators -->
    <color name="ink_rule">#C7C7CC</color>         <!-- stronger rule / marks -->
    <color name="ink_pill_stroke">#D1D1D6</color>  <!-- card / control border -->

    <!--
      Single accent: a bold Boox-style turquoise-green — an action colour (go / growth).
      Saturated enough to read as real colour on Kaleido 3 (where hues desaturate/darken).
      Used ONLY for positive signals: completions, progress, streaks, the active tab, and
      primary actions. Everything else stays monochrome.
    -->
    <color name="ink_accent">#0DA88F</color>
    <color name="ink_accent_dim">#8E8E93</color>
    <color name="ink_fill">#0B0B0C</color>

    <!-- Subtle neutral fill for chip/track backgrounds (used sparingly). -->
    <color name="ink_subtle">#F2F2F4</color>

    <!-- 'teal' name kept (habit checkbox fill) — the turquoise accent. -->
    <color name="ink_teal">#0DA88F</color>
    <color name="ink_gold">#0B0B0C</color>

    <color name="ink_black">#0B0B0C</color>
    <color name="ink_white">#FFFFFF</color>

    <!-- Launcher icon background -->
    <color name="ic_launcher_background">#F8F6F3</color>
</resources>
