<?xml version="1.0" encoding="utf-8"?>
<!-- Habit row: a clean bordered card. Tappable anywhere to toggle completion.
     Anchor cue (optional) sits above; the handwritten/typed name is the focus, with a
     small footnote for the schedule, a streak stat, and a circular check control. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/screen_margin"
    android:paddingEnd="@dimen/screen_margin"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:id="@+id/pillCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/pill_bg"
        android:paddingStart="16dp"
        android:paddingEnd="10dp"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Anchor cue: small gray text above the habit (habit-stacking reminder) -->
        <TextView
            android:id="@+id/anchorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="2dp"
            android:textColor="@color/ink_hint"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="after my morning coffee"
            tools:visibility="visible" />

        <!-- Handwritten anchor cue rendered as ink -->
        <ImageView
            android:id="@+id/anchorInk"
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:layout_marginStart="34dp"
            android:layout_marginBottom="2dp"
            android:adjustViewBounds="true"
            android:scaleType="fitStart"
            android:visibility="gone"
            android:contentDescription="anchor" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/pillIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:tint="@color/ink_text"
                android:contentDescription="habit icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.inkhabits.ui.widget.HabitNameView
                    android:id="@+id/habitName"
                    android:layout_width="match_parent"
                    android:layout_height="42dp" />

                <TextView
                    android:id="@+id/scheduleLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/ink_text_muted"
                    android:textSize="@dimen/text_small"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Morning · 5:00 PM" />
            </LinearLayout>

            <TextView
                android:id="@+id/streakText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:gravity="center_vertical"
                android:drawablePadding="3dp"
                android:textColor="@color/ink_accent"
                android:textSize="13sp"
                android:fontFamily="@font/inter_semibold"
                app:drawableStartCompat="@drawable/ic_flame"
                app:drawableTint="@color/ink_accent"
                tools:text="4" />

            <com.inkhabits.ui.widget.CheckBoxView
                android:id="@+id/checkBox"
                android:layout_width="44dp"
                android:layout_height="44dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
