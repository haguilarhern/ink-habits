<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/screen_margin"
    android:paddingEnd="@dimen/screen_margin"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Timeline rail: vertical line + schedule node -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="match_parent">

        <!-- Full-height vertical line (connects habits above/below) -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="@color/ink_divider" />

        <!-- Schedule node: white patch over the line + rotated time text -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center">

            <View
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:background="@color/ink_background" />

            <TextView
                android:id="@+id/scheduleLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/ink_text_muted"
                android:textSize="11sp"
                android:rotation="-90"
                tools:text="Daily \u00B7 5:00 PM" />
        </FrameLayout>
    </FrameLayout>

    <!-- Context column: anchor text only (vertical, rotated) -->
    <!-- FrameLayout wrappers use 18dp to give rotated text breathing room -->
    <LinearLayout
        android:id="@+id/contextColumn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginEnd="4dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:id="@+id/anchorInkRow"
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:rotation="-90"
            android:clipChildren="false"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="after "
                android:textColor="@color/ink_hint"
                android:textSize="13sp"
                android:textStyle="italic"
                tools:ignore="HardcodedText" />

            <ImageView
                android:id="@+id/anchorInk"
                android:layout_width="50dp"
                android:layout_height="16dp"
                android:scaleType="fitEnd"
                android:contentDescription="anchor" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="18dp"
            android:layout_height="wrap_content"
            android:clipChildren="false">

            <TextView
                android:id="@+id/anchorLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/ink_hint"
                android:textSize="13sp"
                android:textStyle="italic"
                android:rotation="-90"
                android:visibility="gone"
                tools:text="after Dinner"
                tools:visibility="visible" />
        </FrameLayout>
    </LinearLayout>

    <!-- pill card: tappable anywhere to toggle completion -->
    <LinearLayout
        android:id="@+id/pillCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/pill_bg"
        android:paddingStart="14dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/pillIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:textSize="20sp" />

        <com.inkhabits.ui.widget.HabitNameView
            android:id="@+id/habitName"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/streakText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="4dp"
            android:textColor="@color/ink_accent"
            android:textSize="13sp" />

        <com.inkhabits.ui.widget.CheckBoxView
            android:id="@+id/checkBox"
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>
</LinearLayout>
