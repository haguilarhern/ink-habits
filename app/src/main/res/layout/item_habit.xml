<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/screen_margin"
    android:paddingEnd="@dimen/screen_margin"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Timeline rail: vertical line + schedule node -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="match_parent">

        <!-- Full-height vertical line (connects habits above/below) -->
        <View
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="@color/ink_divider" />

        <!-- Schedule node: white patch over the line + rotated time text -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center">

            <View
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:background="@color/ink_background" />

            <TextView
                android:id="@+id/scheduleLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:fontFamily="@font/inter_semibold"
                android:textColor="@color/ink_text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.04"
                android:rotation="-90"
                tools:text="Daily · 5:00 PM" />
        </FrameLayout>
    </FrameLayout>

    <!-- pill card: tappable anywhere to toggle completion -->
    <LinearLayout
        android:id="@+id/pillCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/pill_bg"
        android:paddingStart="16dp"
        android:paddingEnd="10dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground">

        <!-- Anchor cue: small gray text above the habit (habit-stacking reminder) -->
        <TextView
            android:id="@+id/anchorLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="1dp"
            android:textColor="@color/ink_hint"
            android:textSize="12sp"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"
            tools:text="after my morning coffee"
            tools:visibility="visible" />

        <!-- Handwritten anchor cue rendered as ink -->
        <ImageView
            android:id="@+id/anchorInk"
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:layout_marginStart="2dp"
            android:layout_marginBottom="1dp"
            android:adjustViewBounds="true"
            android:scaleType="fitStart"
            android:visibility="gone"
            android:contentDescription="anchor" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/pillIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginEnd="12dp"
                android:tint="@color/ink_text"
                android:contentDescription="habit icon" />

            <com.inkhabits.ui.widget.HabitNameView
                android:id="@+id/habitName"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/streakText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="4dp"
                android:textColor="@color/ink_accent"
                android:textSize="13sp" />

            <com.inkhabits.ui.widget.CheckBoxView
                android:id="@+id/checkBox"
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
