<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/screen_margin"
    android:paddingVertical="12dp">

    <TextView
        android:id="@+id/habitNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/ink_text"
        android:textSize="@dimen/text_header"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/habitNameInk"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:scaleType="fitStart"
        android:visibility="gone"
        android:contentDescription="habit" />

    <TextView
        android:id="@+id/statsLine"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/ink_text_muted"
        android:textSize="@dimen/text_small" />

    <com.inkhabits.ui.widget.HeatmapView
        android:id="@+id/heatmap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/ink_divider" />
</LinearLayout>
