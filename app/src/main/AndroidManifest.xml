<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Exact daily alarms for per-habit reminders. SCHEDULE_EXACT_ALARM is default-
         granted on API 31-32; USE_EXACT_ALARM covers API 33+ (reminder-app use). -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:name=".InkHabitsApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.InkHabits"
        tools:replace="android:label">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.InkHabits">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.history.HistoryActivity"
            android:exported="false" />

        <activity
            android:name=".ui.todo.ToDoActivity"
            android:exported="false" />

        <activity
            android:name=".ui.quote.QuoteEditActivity"
            android:exported="false" />

        <activity
            android:name=".ui.rewards.RewardsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.rewards.AddRewardActivity"
            android:exported="false" />

        <activity
            android:name=".ui.writing.WritingPadActivity"
            android:exported="false"
            android:theme="@style/Theme.InkHabits.Translucent"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Habits widget -->
        <receiver
            android:name=".widget.HabitsWidgetProvider"
            android:label="@string/widget_habits_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.inkhabits.action.TOGGLE_HABIT" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/habits_widget_info" />
        </receiver>
        <service
            android:name=".widget.HabitsWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- To-do widget -->
        <receiver
            android:name=".widget.ToDoWidgetProvider"
            android:label="@string/widget_todo_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.inkhabits.action.TOGGLE_TODO" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/todo_widget_info" />
        </receiver>
        <service
            android:name=".widget.ToDoWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />

        <!-- Quote widget -->
        <receiver
            android:name=".widget.QuoteWidgetProvider"
            android:label="@string/widget_quote_label"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.inkhabits.action.TOGGLE_QUOTE_HW" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/quote_widget_info" />
        </receiver>

        <!-- Per-habit reminder alarms + reschedule on boot -->
        <receiver
            android:name=".notify.HabitReminderReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
